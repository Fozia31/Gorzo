# If set, frontend calls this backend directly.
# Example: https://your-backend-project.vercel.app/api
NEXT_PUBLIC_API_BASE_URL=

# Optional backend URL for Next.js rewrite proxy.
# Example: https://your-backend-project.vercel.app
BACKEND_URL=

# Optional WebSocket endpoint.
# Leave empty on Vercel backend (serverless functions do not support socket.io servers).
NEXT_PUBLIC_WS_URL=
